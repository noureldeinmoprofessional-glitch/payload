# --- Payload ---
# Long random string used to sign/encrypt. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-long-random-secret

# --- Database (MongoDB) ---
# Local:   mongodb://127.0.0.1/knowledge-club
# Atlas:   mongodb+srv://user:pass@cluster.xxxx.mongodb.net/knowledge-club
DATABASE_URI=mongodb://127.0.0.1/knowledge-club

# Public URL of the site (used for absolute links, CORS, previews)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Media storage: Cloudflare R2 (S3-compatible) ---
# Only needed in production (Vercel). Leave blank locally to store on disk.
# From Cloudflare dashboard → R2:
R2_BUCKET=knowledge-club-media
# Endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2 → Manage R2 API Tokens → Create (Object Read & Write):
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
