# --- Payload ---
# Long random string used to sign/encrypt. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-long-random-secret

# --- Database (MongoDB) ---
# Local:   mongodb://127.0.0.1/knowledge-club
# Atlas:   mongodb+srv://user:pass@cluster.xxxx.mongodb.net/knowledge-club
DATABASE_URI=mongodb://127.0.0.1/knowledge-club

# Public URL of the site (used for absolute links, CORS, previews)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
